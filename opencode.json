{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "wealth-guide",
  "instructions": [
    ".opencode/instructions/data-priority.md",
    ".opencode/instructions/quant-research.md",
    ".opencode/instructions/wealth-guide-router.md"
  ],
  "mcp": {
    "morningstar": {
      "type": "remote",
      "url": "https://mcp.morningstar.com/mcp"
    },
    "factset": {
      "type": "remote",
      "url": "https://mcp.factset.com/content/v1"
    },
    "ddg-search": {
      "type": "local",
      "command": ["uvx", "duckduckgo-mcp-server"],
      "enabled": true
    }
  },
  "agent": {
